generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- Sources catalogue (V3 : plusieurs providers) ---

enum CatalogSource {
  bedetheque
  local
}

enum ImportJobStatus {
  pending
  running
  success
  partial_success
  failed
}

enum OwnershipStatus {
  NOT_OWNED
  OWNED
  WANTED
  HUNTING
  DUPLICATE
}

enum EditionStatus {
  UNKNOWN
  FIRST_EDITION
  NOT_FIRST_EDITION
}

enum EditionConfidence {
  TO_VERIFY
  PROBABLE
  CONFIRMED
}

enum ConditionGrade {
  UNKNOWN
  MINT
  EXCELLENT
  VERY_GOOD
  GOOD
  FAIR
  POOR
}

enum CompletenessStatus {
  COMPLETE
  INCOMPLETE
  UNKNOWN
}

enum SearchStatus {
  NONE
  WANTED
  HUNTING
}

/// Données importées / référentiel (≠ possession)
model SeriesReference {
  id             String        @id @default(cuid())
  source         CatalogSource
  sourceSeriesId String
  sourceUrl      String
  title          String
  slug           String
  universe       String?
  summary        String?
  status         String?
  albumCount     Int           @default(0)
  coverImageUrl  String?
  sourceName     String?
  rawPayload     Json?
  firstFetchedAt DateTime
  lastFetchedAt  DateTime
  lastRefreshAt  DateTime?
  cacheExpiresAt DateTime
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  albums   AlbumReference[]
  importJobs ImportJob[]

  @@unique([source, sourceSeriesId])
  @@index([slug])
  @@index([title])
  @@map("series_references")
}

model AlbumReference {
  id                 String    @id @default(cuid())
  seriesReferenceId  String
  externalId         String
  code               String?
  volumeNumber       Int?
  volumeLabel        String?
  title              String
  subtitle           String?
  authors            String?
  publisher          String?
  publicationDate    DateTime?
  legalDeposit       String?
  isbn               String?
  pageCount          Int?
  format             String?
  weight             String?
  rating             Float?
  ratingCount        Int?
  estimate           String?
  editionLabel       String?
  isOriginalEdition  Boolean?
  coverImageUrl      String?
  summary            String?
  rawPayload         Json?
  knownEditionsCount Int       @default(0)
  sourceName         String?
  sourceAlbumUrl     String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  seriesReference SeriesReference @relation(fields: [seriesReferenceId], references: [id], onDelete: Cascade)
  collectionItems CollectionItem[]

  @@unique([seriesReferenceId, externalId])
  @@index([seriesReferenceId])
  @@index([isbn])
  @@map("album_references")
}

/// Exemplaire / suivi personnel lié à une fiche catalogue
model CollectionItem {
  id                String              @id @default(cuid())
  albumReferenceId  String
  ownershipStatus   OwnershipStatus     @default(NOT_OWNED)
  searchStatus      SearchStatus        @default(NONE)
  editionStatus     EditionStatus       @default(UNKNOWN)
  editionConfidence EditionConfidence   @default(TO_VERIFY)
  conditionGrade    ConditionGrade      @default(UNKNOWN)
  completenessStatus CompletenessStatus @default(UNKNOWN)
  hasPersonalPhoto  Boolean             @default(false)
  personalPhotoUrl  String?
  purchasePrice     Decimal?            @db.Decimal(12, 2)
  purchaseDate      DateTime?
  purchaseSource    String?
  notes             String?
  isDuplicate       Boolean             @default(false)
  quantity          Int                 @default(1)
  metadataJson      Json?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  albumReference AlbumReference @relation(fields: [albumReferenceId], references: [id], onDelete: Cascade)

  @@index([albumReferenceId])
  @@index([ownershipStatus])
  @@map("collection_items")
}

model ImportJob {
  id                String            @id @default(cuid())
  source            CatalogSource
  sourceUrl         String
  status            ImportJobStatus   @default(pending)
  startedAt         DateTime?
  finishedAt        DateTime?
  seriesReferenceId String?
  logs              String            @default("")
  errorMessage      String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  seriesReference SeriesReference? @relation(fields: [seriesReferenceId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([sourceUrl])
  @@index([createdAt])
  @@map("import_jobs")
}
